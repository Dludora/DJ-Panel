DATABASE_URL=postgresql+psycopg:///dj_panel
APP_ENV=dev
CLAIM_LEASE_SECONDS=900
DJ_PANEL_BASE_URL=http://127.0.0.1:8000
DJ_PANEL_HOST=127.0.0.1
DJ_PANEL_PORT=8000
DJ_PANEL_WEB_HOST=127.0.0.1
DJ_PANEL_WEB_PORT=1337
DJ_PANEL_WEB_OPEN=false
DJ_PANEL_HTTP_TIMEOUT_SECONDS=30
DJ_PANEL_WORKDIR=/tmp/dj-panel-worker
DJ_PANEL_WORKER_POLL_INTERVAL_SECONDS=0
DJ_PANEL_DJ_BIN=dj-process
DJ_PANEL_DJ_CONFIG_ARG=--config
DJ_PANEL_RECIPE_TIMEOUT_SECONDS=7200
DJ_PANEL_CLI_CONFIG_PATH=~/.config/dj-panel/config.json
